{
  "discovery": {
    "maxDepth": 2,
    "seedKols": [
      "IncomeSharks",
      "AltcoinSherpa",
      "AltcoinDailyio",
      "cobie",
      "DoveyWan",
      "CryptoMichNL",
      "coinbureau",
      "Defi_gazer"
    ],
    "maxKolsPerLevel": 50,
    "processingBatchSize": 2
  },
  "kolCriteria": {
    "minFollowers": 1000,
    "maxFollowers": 1000000,
    "minCryptoRelevance": 70,
    "recentActivityWindowDays": 7,
    "minEngagementRate": 0.03,
    "minAverageLikes": 10,
    "minAverageViews": 100,
    "requireVerified": false
  },
  "replySettings": {
    "maxRepliesPerRun": 2,
    "maxRepliesPerDay": 10,
    "maxRepliesPerKolPerWeek": 3,
    "minRelevanceScoreForReply": 60,
    "minTimeBetweenRepliesMinutes": 30,
    "dryRun": false
  },
  "rateLimits": {
    "twitterApiCallsPerMinute": 15,
    "claudeApiCallsPerMinute": 50,
    "waitBetweenBatchesMs": 10000,
    "maxSearchQueriesPerRun": 2,
    "maxKolsToEvaluatePerRun": 30
  },
  "bwsProductsSource": "docs-index.json",
  "spamPrevention": {
    "avoidCompetitors": [
      "competitor1",
      "competitor2"
    ],
    "avoidKeywords": [
      "buy now",
      "guaranteed",
      "free money",
      "airdrop",
      "giveaway"
    ],
    "requirePositiveSentiment": false,
    "skipPromotionalPosts": true,
    "maxConsecutiveFailures": 3
  },
  "monitoring": {
    "trackBlockedIndicators": true,
    "trackEngagementMetrics": true,
    "alertOnSpamDetection": true,
    "reportingIntervalDays": 7
  },
  "searchDiscovery": {
    "enabled": true,
    "queriesFile": "search-queries.json",
    "engagementTier": "tier4",
    "minFollowersOverride": 500,
    "deduplicateExisting": true
  },
  "positioningPhrases": [
    "microcap opportunity with real fundamentals",
    "project generating revenue and building real products",
    "project with real blockchain utility and working APIs",
    "project bringing the AWS vision to blockchain solutions",
    "project bringing Web3 solutions to mass markets",
    "undervalued project with consistent product delivery",
    "project that continues building in any market condition",
    "project with multiple live products and real traction",
    "microcap with strong fundamentals and long-term vision",
    "project focused on real-world blockchain applications"
  ],
  "contentDiversity": {
    "preventConsecutiveSameProduct": true,
    "includeReplyHistoryContext": true,
    "maxRecentRepliesToInclude": 3,
    "specialNotesProbability": 0.33
  }
}