{
  "discovery": {
    "maxDepth": 2,
    "seedKols": ["IncomeSharks"],
    "maxKolsPerLevel": 50,
    "processingBatchSize": 10
  },
  "kolCriteria": {
    "minFollowers": 1000,
    "minCryptoRelevance": 70,
    "recentActivityWindowDays": 7,
    "minEngagementRate": 0.03,
    "minAverageLikes": 10,
    "minAverageViews": 100,
    "requireVerified": false
  },
  "replySettings": {
    "maxRepliesPerRun": 1,
    "maxRepliesPerDay": 7,
    "maxRepliesPerKolPerWeek": 1,
    "minRelevanceScoreForReply": 70,
    "minTimeBetweenRepliesMinutes": 30,
    "dryRun": false
  },
  "rateLimits": {
    "twitterApiCallsPerMinute": 20,
    "claudeApiCallsPerMinute": 50,
    "waitBetweenBatchesMs": 5000,
    "maxSearchQueriesPerRun": 2,
    "maxKolsToEvaluatePerRun": 5
  },
  "bwsProductsSource": "docs-index.json",
  "spamPrevention": {
    "avoidCompetitors": ["competitor1", "competitor2"],
    "avoidKeywords": ["buy now", "guaranteed", "free money", "airdrop", "giveaway"],
    "requirePositiveSentiment": false,
    "skipPromotionalPosts": true,
    "maxConsecutiveFailures": 3
  },
  "monitoring": {
    "trackBlockedIndicators": true,
    "trackEngagementMetrics": true,
    "alertOnSpamDetection": true,
    "reportingIntervalDays": 7
  },
  "searchDiscovery": {
    "enabled": true,
    "queriesFile": "search-queries.json",
    "engagementTier": "tier2",
    "minFollowersOverride": 500,
    "deduplicateExisting": true
  }
}
