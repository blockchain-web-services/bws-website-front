{
  "discovery": {
    "enabled": true,
    "interval": "daily",
    "maxNewKolsPerRun": 10
  },
  "kolCriteria": {
    "minFollowers": 10000,
    "maxFollowers": 500000,
    "minEngagementRate": 0.01,
    "cryptoRelevanceThreshold": 50
  },
  "replySettings": {
    "enabled": true,
    "maxRepliesPerRun": 8,
    "maxTweetsToEvaluatePerRun": 20,
    "maxRepliesPerDay": 60,
    "maxRepliesPerKolPerWeek": 3,
    "minRelevanceScoreForReply": 6,
    "minTimeBetweenRepliesMinutes": 45,
    "dryRun": false,
    "antiSpamActions": {
      "followKolBeforeReply": true,
      "likeTweetBeforeReply": true,
      "onlyIfNotAlreadyFollowing": true,
      "skipOnError": true
    },
    "imageAttachments": {
      "enabled": true,
      "attachOnlyWhenAvailable": true,
      "skipReplyOnUploadFailure": false
    },
    "minTimeBetweenReplies": 2700,
    "replyTemplates": [
      "Insightful perspective on {topic}! Have you explored {bws_product}? It might complement your {use_case}.",
      "Great thread! {bws_product} could help with {problem}. Would love to hear your thoughts."
    ]
  },
  "contentDiversity": {
    "preventConsecutiveSameProduct": true,
    "specialNotesProbability": 0.33
  },
  "freshnessFilter": {
    "enabled": true,
    "maxTweetAgeHours": 36,
    "cleanupThresholdHours": 72,
    "fallbackToAddedAt": true,
    "description": "Only reply to tweets less than 36 hours old for maximum engagement impact"
  },
  "monitoring": {
    "checkInterval": 21600,
    "maxPostsPerKol": 20,
    "relevanceThreshold": 60
  }
}
