{
  "name": "bws-website",
  "version": "1.0.0",
  "description": "Blockchain Web Services website - migrated from Webflow",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/clean-build.js",
    "build": "astro build && npm run postbuild",
    "build:only": "astro build",
    "postbuild": "npm run pretty-print && npm run validate",
    "preview": "astro preview",
    "preview:sirv": "sirv _site --port 4321 --host",
    "test:setup": "npx playwright install chromium",
    "test": "playwright test --config=tests/playwright.config.cjs",
    "test:ui": "playwright test --config=tests/playwright.config.cjs --ui",
    "test:smoke": "playwright test tests/smoke/ --config=tests/playwright.config.cjs",
    "test:visual": "playwright test tests/visual/ --config=tests/playwright.config.cjs",
    "test:a11y": "playwright test tests/accessibility/ --config=tests/playwright.config.cjs",
    "test:perf": "playwright test tests/performance/ --config=tests/playwright.config.cjs",
    "test:e2e": "playwright test tests/e2e/ --config=tests/playwright.config.cjs",
    "test:headed": "playwright test --config=tests/playwright.config.cjs --headed",
    "test:debug": "playwright test --config=tests/playwright.config.cjs --debug",
    "test:report": "playwright show-report tests/playwright-report",
    "crawl": "node scripts/crawler/crawl-standalone.js",
    "redownload": "node scripts/redownload-all-pages.js",
    "validate": "node scripts/validate-html.js",
    "pretty-print": "node scripts/pretty-print-validate.js"
  },
  "keywords": [
    "blockchain",
    "web3",
    "bws"
  ],
  "author": "Blockchain Web Services",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@lhci/cli": "^0.13.0",
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.0.0",
    "astro": "^4.16.18",
    "cheerio": "^1.1.2",
    "linkinator": "^6.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "sirv-cli": "^3.0.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.2"
  }
}
