{
  "name": "bws-website",
  "version": "1.0.0",
  "type": "module",
  "description": "BWS Website - Blockchain Web Services static site built with Astro",
  "scripts": {
    "dev": "astro dev --port 8087",
    "start": "astro dev --port 8087",
    "prebuild": "node scripts/clean-build.js",
    "build": "npm run prebuild && astro build",
    "build:validate": "node scripts/build-with-validation.js",
    "build:only": "astro build",
    "build:fast": "npm run prebuild && astro build",
    "postbuild": "npm run pretty-print && npm run validate",
    "preview": "astro preview",
    "crawl": "node scripts/crawler/crawl-standalone.js",
    "redownload": "node scripts/redownload-all-pages.js",
    "validate": "node scripts/html-validator.js",
    "validate:old": "node scripts/validate-html.js",
    "prettify": "node scripts/html-prettifier.js",
    "pretty-print": "node scripts/pretty-print-validate.js",
    "format": "prettier --write 'src/**/*.{astro,js,ts,json}'",
    "format:check": "prettier --check 'src/**/*.{astro,js,ts,json}'",
    "snapshot": "cd tests && npx playwright test visual/snapshots.spec.js --config=playwright.config.cjs",
    "snapshot:update": "npm run build && npm run snapshot",
    "weekly-x-post": "node scripts/generate-weekly-x-post.js",
    "worktree:create": "node scripts/worktree/create-worktree.mjs",
    "worktree:list": "node scripts/worktree/list-worktrees.mjs",
    "worktree:merge": "node scripts/worktree/merge-worktree.mjs",
    "worktree:remove": "node scripts/worktree/remove-worktree.mjs"
  },
  "devDependencies": {
    "@octokit/rest": "^22.0.0",
    "@types/node": "^20.0.0",
    "astro": "^4.16.18",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "html-validator": "^6.0.0",
    "linkinator": "^6.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.1",
    "@blockchain-web-services/bws-x-sdk-node": "^1.10.0",
    "@rollup/rollup-linux-x64-gnu": "^4.50.2",
    "@the-convocation/twitter-scraper": "^0.20.1",
    "crawlee": "^3.15.2",
    "playwright": "^1.56.1",
    "playwright-extra": "^4.3.6",
    "puppeteer": "^24.29.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "twitter-api-v2": "^1.27.0"
  }
}
