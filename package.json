{
  "name": "bws-website",
  "version": "1.0.0",
  "description": "Blockchain Web Services website - migrated from Webflow to GitHub Pages",
  "main": "index.js",
  "scripts": {
    "start": "eleventy --serve --port=8081",
    "build": "node scripts/build.js",
    "build:eleventy": "eleventy",
    "watch": "eleventy --watch",
    "serve": "eleventy --serve --port=8081",
    "debug": "DEBUG=* eleventy",
    "crawl": "node scripts/crawler/crawl-standalone.js",
    "generate-data": "node scripts/data-generation/generate-page-data.js",
    "validate": "node scripts/validation/validate-crawl.js",
    "deploy": "bash scripts/deploy.sh",
    "deploy:test": "npm run build && npx http-server _site -p 8080",
    "clean": "rm -rf _site .cache",
    "prebuild": "npm run clean",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:report": "playwright show-report",
    "test:links": "playwright test tests/link-integrity.spec.ts",
    "test:seo": "playwright test tests/seo-validation.spec.ts",
    "test:a11y": "playwright test tests/accessibility.spec.ts",
    "test:content": "playwright test tests/content-validation.spec.ts",
    "test:all": "npm run test:links && npm run test:seo && npm run test:a11y && npm run test:content",
    "validate:html": "html-validate _site/**/*.html --config .htmlvalidate.json",
    "lint:html": "htmlhint _site/**/*.html --config .htmlhintrc",
    "format:html": "prettier --write src/**/*.njk --ignore-path .gitignore",
    "format:html:check": "prettier --check src/**/*.njk --ignore-path .gitignore",
    "check:html": "npm run validate:html && npm run lint:html && npm run format:html:check"
  },
  "keywords": [
    "blockchain",
    "web3",
    "bws"
  ],
  "author": "Blockchain Web Services",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.5.0",
    "cheerio": "^1.1.2",
    "html-validate": "^10.0.0",
    "htmlhint": "^1.7.0",
    "http-server": "^14.1.1",
    "node-fetch": "^3.3.2",
    "nunjucks": "^3.2.4",
    "prettier": "^3.6.2",
    "typescript": "^5.5.0"
  }
}
