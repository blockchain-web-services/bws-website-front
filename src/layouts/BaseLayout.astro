  title = "A Growing Marketplace of AI-Built Solutions",
  description = "Our consolidated AI workflow turns validated market demand into production-ready solutions — fast. Every solution carries a blockchain dimension, delivered when it meaningfully deepens the customer outcome.",
} = Astro.props;
