    <slot />

    <slot name="scripts" />

    <!-- jQuery (required for Webflow) -->
    <script src="/assets/js/jquery-3.5.1.min.dc5e7f18c8.js" type="text/javascript"></script>

    <!-- Patch Webflow initialization to handle missing modules gracefully -->
    <script type="text/javascript">
      // Store original jQuery ready function
      if (typeof $ !== "undefined" && $.fn && $.fn.ready) {
        var originalReady = $.fn.ready;
        var pendingCallbacks = [];

        // Override jQuery ready to intercept Webflow's initialization
        $.fn.ready = function (callback) {
          // Store callbacks for later
          pendingCallbacks.push(callback);
          // Don't execute immediately
          return this;
        };

        // After all scripts load, execute callbacks with error handling
        window.addEventListener("load", function () {
          // Restore original ready function
          $.fn.ready = originalReady;

          // Execute pending callbacks with error handling
          pendingCallbacks.forEach(function (callback) {
            try {
              callback.call(document);
            } catch (e) {
              console.log("Webflow module initialization skipped (missing dependencies)");
            }
          });
        });
      }
    </script>

    <!-- Webflow JavaScript for dropdown menus and interactions -->
    <script src="/assets/js/webflow.schunk.6d83011aa4f34449.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.schunk.1ad200ed633c14bf.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.schunk.4913f0d9ee368d76.js" type="text/javascript"></script>
    <script src="/assets/js/webflow.00c81055.72e38c471fcb0085.js" type="text/javascript"></script>

    <!-- Manually initialize Webflow components that work -->
    <script type="text/javascript">
      window.addEventListener("load", function () {
        setTimeout(function () {
          if (typeof Webflow !== "undefined") {
            // Try to initialize navigation dropdowns specifically
            if (Webflow.nav && Webflow.nav.ready) {
              try {
                Webflow.nav.ready();
              } catch (e) {
                console.log("Nav initialization issue:", e);
              }
            }

            // Initialize any other working modules
            if (Webflow.tabs && Webflow.tabs.ready) {
              try {
                Webflow.tabs.ready();
              } catch (e) {}
            }
          }
        }, 200);
      });
    </script>

    <!-- Dynamic Roadmap Colors based on current date -->
    <script type="text/javascript" define:vars={{ quarterLearnings, quarterContents }}>
      (function() {
        // Learnings data imported from /src/data/quarterLearnings.ts
        // Quarter content data imported from /src/data/quarterContent.ts

        // Function to get current quarter (1-4)
        function getCurrentQuarter() {
          const now = new Date();
          const month = now.getMonth(); // 0-11
          return Math.floor(month / 3) + 1; // 1-4
        }

        // Function to get current year
        function getCurrentYear() {
          return new Date().getFullYear();
        }

        // Function to inject quarter content into roadmap cards
        function injectQuarterContent(card, quarter, year) {
          // Determine the key for looking up content
          let key;
          if (quarter && year) {
            key = year + '-' + quarter;
          } else if (card.hasAttribute('data-roadmap-key')) {
            // Use the data-roadmap-key attribute for LAUNCH and 2026
            key = card.getAttribute('data-roadmap-key');
          }

          const data = quarterContents[key];

          // Skip if no content data exists
          if (!data) return;

          // Check if content already injected (prevent duplicates)
          if (card.querySelector('.container-roadmap-content .w-richtext')) {
            const existingContent = card.querySelector('.container-roadmap-content .w-richtext');
            if (existingContent && existingContent.children.length > 0) {
              return; // Content already exists
            }
          }

          // Build heading
          let headingHTML = '';
          if (data.quarter === 'LAUNCH' || data.quarter === '2026') {
            headingHTML = '<div class="heading-roadmap">' + data.quarter + '</div>';
          } else {
            headingHTML = '<div class="heading-roadmap">Q' + data.quarter + '\' <span class="text-span-11">' + data.year + '</span></div>';
          }

          // Build title
          const titleHTML = '<div class="' + data.titleCssClass + '">' + data.title + '</div>';

          // Build sections
          let sectionsHTML = '';
          data.sections.forEach(function(section) {
            sectionsHTML += '<h4 class="roadmap-description-title">' + section.title + '</h4>';
            section.paragraphs.forEach(function(para) {
              sectionsHTML += '<p class="paragraph-10">' + para + '</p>';
            });
          });

          // Complete content HTML
          const contentHTML = '<div class="w-layout-blockcontainer container-roadmap-content w-container">' +
            '<div class="w-richtext">' + sectionsHTML + '</div>' +
          '</div>';

          // Clear card and inject new content
          card.innerHTML = headingHTML + titleHTML + contentHTML;
        }

        // Function to inject learnings section into past quarter cards
        function injectLearningsSection(card, quarter, year) {
          const key = year + '-' + quarter;
          const data = quarterLearnings[key];

          // Skip if no learnings data exists yet
          if (!data) return;

          // Check if learnings already injected (prevent duplicates)
          if (card.querySelector('.roadmap-learnings-container')) return;

          // Build achieved list
          let achievedHTML = '';
          data.achieved.forEach(function(item) {
            achievedHTML += '<li>' + item + '</li>';
          });

          // Build missed list
          let missedHTML = '';
          data.missed.forEach(function(item) {
            missedHTML += '<li>' + item + '</li>';
          });

          // Build lessons list
          let lessonsHTML = '';
          data.lessons.forEach(function(item) {
            lessonsHTML += '<li>' + item + '</li>';
          });

          // Build missed section only if there are items
          let missedSection = '';
          if (data.missed.length > 0) {
            missedSection = '<div class="learnings-section">' +
              '<h4 class="learnings-heading">What We Didn\'t Complete</h4>' +
              '<ul class="learnings-list">' + missedHTML + '</ul>' +
            '</div>';
          }

          // Complete HTML structure
          const html = '<div class="roadmap-learnings-container">' +
            '<button class="roadmap-learnings-toggle" aria-expanded="false" type="button">' +
              '<span class="learnings-label">Quarter Learnings</span>' +
              '<span class="learnings-arrow">▼</span>' +
            '</button>' +
            '<div class="roadmap-learnings-content">' +
              '<div class="learnings-section">' +
                '<h4 class="learnings-heading">What We Achieved</h4>' +
                '<ul class="learnings-list">' + achievedHTML + '</ul>' +
              '</div>' +
              missedSection +
              '<div class="learnings-section">' +
                '<h4 class="learnings-heading">Key Lessons</h4>' +
                '<ul class="learnings-list">' + lessonsHTML + '</ul>' +
              '</div>' +
            '</div>' +
          '</div>';

          // Calculate spacer height to align learnings across cards in same row
          const parentRow = card.closest('.split-horizontal');
          let spacerHeight = 0;
          if (parentRow) {
            const cardsInRow = parentRow.querySelectorAll('[data-quarter][data-year]');
            let maxContentHeight = 0;
            cardsInRow.forEach(function(rowCard) {
              const contentArea = rowCard.querySelector('.container-roadmap-content');
              if (contentArea && contentArea.offsetHeight > maxContentHeight) {
                maxContentHeight = contentArea.offsetHeight;
              }
            });
            const thisContentHeight = card.querySelector('.container-roadmap-content').offsetHeight;
            spacerHeight = maxContentHeight - thisContentHeight;
          }

          const spacer = document.createElement('div');
          spacer.className = 'roadmap-flex-spacer';
          spacer.style.cssText = 'flex: 0 0 auto; height: ' + spacerHeight + 'px;';
          card.appendChild(spacer);

          // Insert learnings at end of card
          card.insertAdjacentHTML('beforeend', html);

          // Add toggle functionality
          const toggle = card.querySelector('.roadmap-learnings-toggle');
          const content = card.querySelector('.roadmap-learnings-content');

          toggle.addEventListener('click', function() {
            const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
            toggle.setAttribute('aria-expanded', !isExpanded);
            content.classList.toggle('expanded');
          });
        }

        // Function to apply dynamic colors to roadmap cards
        function applyDynamicRoadmapColors() {
          const currentQuarter = getCurrentQuarter();
          const currentYear = getCurrentYear();

          // First, inject content for all cards with data attributes
          const quarterCards = document.querySelectorAll('[data-quarter][data-year]');
          quarterCards.forEach(function(card) {
            const cardQuarter = parseInt(card.getAttribute('data-quarter'));
            const cardYear = parseInt(card.getAttribute('data-year'));
            injectQuarterContent(card, cardQuarter, cardYear);
          });

          // Also handle LAUNCH and 2026 cards (with data-roadmap-key)
          const specialCards = document.querySelectorAll('[data-roadmap-key]');
          specialCards.forEach(function(card) {
            injectQuarterContent(card);
          });

          // Now apply dynamic colors to cards with data attributes
          quarterCards.forEach(function(card) {
            const cardQuarter = parseInt(card.getAttribute('data-quarter'));
            const cardYear = parseInt(card.getAttribute('data-year'));

            // Calculate if this card is past, current, or future
            let cardClass = '';

            if (cardYear < currentYear) {
              // Past year - all quarters are past
              cardClass = 'roadmap-past';
            } else if (cardYear > currentYear) {
              // Future year - all quarters are future
              cardClass = 'roadmap-future';
            } else {
              // Same year - compare quarters
              if (cardQuarter < currentQuarter) {
                cardClass = 'roadmap-past';
              } else if (cardQuarter === currentQuarter) {
                cardClass = 'roadmap-current';
              } else {
                cardClass = 'roadmap-future';
              }
            }

            // Remove any existing roadmap color classes
            card.classList.remove('roadmap-past', 'roadmap-current', 'roadmap-future');

            // Add the appropriate class
            card.classList.add(cardClass);

            // Inject learnings section for past quarters
            if (cardClass === 'roadmap-past') {
              injectLearningsSection(card, cardQuarter, cardYear);
            }
          });
        }

        // Run on page load
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', applyDynamicRoadmapColors);
        } else {
          applyDynamicRoadmapColors();
        }
      })();
    </script>
  </body>
</html>
