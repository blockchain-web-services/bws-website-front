---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import IndustryContentContentCreationMainContent from "../../components/industrycontentcontentcreationMainContent.astro";

const pageTitle = "Content Creation — Blockchain & AI Solutions for Creators | BWS";
const pageDescription = "BWS solutions for content creators — content provenance, NFT minting, and audience analytics powered by an AI-native, blockchain-ready stack.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><IndustryContentContentCreationMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
