---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import IndustryContentLegalMainContent from "../../components/industrycontentlegalMainContent.astro";

const pageTitle = "Legal — Blockchain Solutions for Law & Compliance | BWS";
const pageDescription = "BWS solutions for the legal sector — immutable record-keeping, document notarization, and verifiable credentials with full audit trails.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><IndustryContentLegalMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
