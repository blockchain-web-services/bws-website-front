---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import IndustryContentEsgMainContent from "../../components/industrycontentesgMainContent.astro";

const pageTitle = "ESG — Environmental, Social & Governance Solutions | BWS";
const pageDescription = "Blockchain-backed ESG solutions from BWS — transparent sustainability reporting, verifiable carbon and impact data, and audit-ready governance records.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><IndustryContentEsgMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
