---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import IndustryContentRetailMainContent from "../../components/industrycontentretailMainContent.astro";

const pageTitle = "Retail - BWS Solutions";
const pageDescription = "BWS — Enterprise solutions built for real market demand, powered by an AI-native workflow.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><IndustryContentRetailMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
