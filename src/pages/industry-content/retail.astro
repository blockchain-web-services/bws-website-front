---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import IndustryContentRetailMainContent from "../../components/industrycontentretailMainContent.astro";

const pageTitle = "Retail — Blockchain & AI Solutions for Commerce | BWS";
const pageDescription = "BWS solutions for retail — supply-chain provenance, digital credentials, and customer engagement built on an AI-native, blockchain-ready stack.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><IndustryContentRetailMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
