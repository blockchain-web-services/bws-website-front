---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Scripts from "../components/Scripts.astro";
import IndustriesMainContent from "../components/industriesMainContent.astro";

const pageTitle = "Industries — Blockchain & AI Solutions by Sector | BWS";
const pageDescription = "How BWS applies its AI-native, blockchain-ready product workflow across finance, retail, legal, supply chain, ESG, and content creation.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation />
  <IndustriesMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
