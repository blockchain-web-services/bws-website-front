---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import WhitePaperMainContent from "../components/WhitePaperMainContent.astro";
import Footer from "../components/Footer.astro";
import Scripts from "../components/Scripts.astro";

const pageTitle = "White Paper - Blockchain Web Services";
const pageDescription = "Read the official Blockchain Web Services white paper: Blockchain Everywhere, for Everyone. Learn about our vision, platform architecture, tokenomics, and NFT Game Cube solution.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation />
  <WhitePaperMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
