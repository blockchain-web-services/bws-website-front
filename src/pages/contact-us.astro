---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import Scripts from "../components/Scripts.astro";
import ContactUsMainContent from "../components/contactusMainContent.astro";

const pageTitle = "BWS - Contact Us";
const pageDescription = "Get in touch with BWS — talk to our team about building market-demand-first software products with an optional blockchain dimension.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation /><ContactUsMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
