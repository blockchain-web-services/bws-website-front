---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import MarketplacetelegramxbotMainContent from "../../components/marketplacetelegramxbotMainContent.astro";

const pageTitle = "Telegram XBot — Track X (Twitter) KOLs & Community Activity | BWS";
const pageDescription = "Telegram XBot tracks X (Twitter) activity and surfaces your top community contributors and KOLs, with daily performance reports delivered straight to Telegram.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation />
  <MarketplacetelegramxbotMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
