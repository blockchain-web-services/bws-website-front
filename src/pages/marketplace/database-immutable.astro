---
// Permanent redirect: Blockchain Save was merged into Blockchain Database.
const target = "/marketplace/blockchain-database.html";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Blockchain Database (formerly Blockchain Save) - BWS</title>
    <meta name="robots" content="noindex" />
    <link rel="canonical" href={`https://www.bws.ninja${target}`} />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body>
    <p>This solution has moved. <a href={target}>Continue to Blockchain Database →</a></p>
  </body>
</html>
