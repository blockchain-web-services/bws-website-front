---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import Scripts from "../../components/Scripts.astro";
import MarketplacenftzeroknwoledgeMainContent from "../../components/marketplacenftzeroknwoledgeMainContent.astro";

const pageTitle = "NFT.zK — Mint NFTs via API with Zero-Knowledge Proofs | BWS";
const pageDescription = "NFT.zK is a simple REST API to mint NFTs without Web3 expertise — privacy-preserving zero-knowledge proofs, no wallets or gas to manage. Mint from your own backend.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation />
  <MarketplacenftzeroknwoledgeMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
