---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="page-wrapper">
    <div class="container w-container">
      <div style="padding: 100px 20px; text-align: center;">
        <h1>404 - Page Not Found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="button-primary w-button">Return to Homepage</a>
      </div>
    </div>
  </div>
  
  <script is:inline>
    // For static hosting compatibility, redirect immediately for non-existent pages
    (function() {
      const path = window.location.pathname;
      const isNonExistentPage = path !== '/' && path !== '/404.html' && !path.includes('/assets/');
      
      if (isNonExistentPage) {
        // Immediately redirect to home for non-existent pages
        window.location.replace('/');
      }
    })();
    
    // Fallback redirect after a brief delay for SEO/testing
    setTimeout(() => {
      if (window.location.pathname !== '/' && window.location.pathname !== '/404.html') {
        window.location.replace('/');
      }
    }, 100);
  </script>
</BaseLayout>