---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="page-wrapper">
    <div class="container w-container">
      <div style="padding: 100px 20px; text-align: center;">
        <h1>404 - Page Not Found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="button-primary w-button">Return to Homepage</a>
      </div>
    </div>
  </div>
  
  <!-- Add meta refresh as fallback for non-JS environments -->
  <script>
    // After 5 seconds, redirect to home if user doesn't click
    setTimeout(() => {
      if (confirm('Page not found. Would you like to return to the homepage?')) {
        window.location.href = '/';
      }
    }, 5000);
  </script>
</BaseLayout>