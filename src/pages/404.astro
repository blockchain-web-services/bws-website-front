---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="page-wrapper">
    <div class="container w-container">
      <div style="padding: 100px 20px; text-align: center;">
        <h1>404 - Page Not Found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="button-primary w-button">Return to Homepage</a>
      </div>
    </div>
  </div>
  
  <script is:inline>
    // Immediate redirect for non-existent pages - highest priority  
    if (typeof window !== 'undefined') {
      const path = window.location.pathname;
      const isNonExistentPage = path !== '/' && path !== '/404.html' && path !== '/404' && !path.includes('/assets/');
      
      if (isNonExistentPage) {
        // Use both href and replace to ensure redirect works
        window.location.href = '/';
        window.location.replace('/');
      }
    }
    
    // Additional fallback using timeout
    (function() {
      setTimeout(() => {
        const path = window.location.pathname;
        if (path !== '/' && path !== '/404.html' && path !== '/404' && !path.includes('/assets/')) {
          window.location.href = '/';
        }
      }, 50);
    })();
  </script>
</BaseLayout>