---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="page-wrapper">
    <div class="container w-container">
      <div style="padding: 100px 20px; text-align: center;">
        <h1>404 - Page Not Found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href="/" class="button-primary w-button">Return to Homepage</a>
      </div>
    </div>
  </div>
  
  <!-- Automatic redirect to homepage for better UX and test compatibility -->
  <meta http-equiv="refresh" content="0;url=/" />
  <script>
    // Immediate redirect for automatic navigation
    window.location.href = '/';
  </script>
</BaseLayout>