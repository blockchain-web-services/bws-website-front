---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import IndexMainContent from "../components/IndexMainContent.astro";
import Footer from "../components/Footer.astro";
import Scripts from "../components/Scripts.astro";

const pageTitle = "Solutions Built Fast, Built Right";
const pageDescription =
  "Our consolidated AI workflow turns validated market demand into production-ready solutions — fast. Every solution carries a blockchain dimension, delivered when it meaningfully deepens the customer outcome.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation />
  <IndexMainContent />
  <Footer />

  <Fragment slot="scripts">
    <Scripts />
  </Fragment>
</BaseLayout>
