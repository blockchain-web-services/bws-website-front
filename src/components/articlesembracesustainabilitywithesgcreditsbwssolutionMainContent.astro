---
// Main content for articles/embrace-sustainability-with-esg-credits-bws-solution page

// Calculate stable date: 4 months ago, day 12
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const articleDate = new Date(currentYear, currentMonth - 4, 12);

// Validate: ensure date is not in the future
const displayDate = articleDate > now ? now : articleDate;

// Format as "MMM DD, YYYY"
const formattedDate = displayDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

