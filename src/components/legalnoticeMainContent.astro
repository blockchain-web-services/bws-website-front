    color: #555;
  }

  .legal-text p {
    margin-bottom: 15px;
  }

  .legal-text ul {
    margin: 20px 0;
    padding-left: 30px;
  }

  .legal-text li {
    margin-bottom: 10px;
    list-style-type: disc;
  }

  .legal-text a {
    color: #0066cc;
    text-decoration: none;
  }

  .legal-text a:hover {
