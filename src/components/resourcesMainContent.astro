---
// Resources / Articles index. Lists every article page so they are internally
// linked (they were previously orphaned — reachable only via the sitemap).
// Titles/descriptions are parsed from each article page at build time.
const rawArticles = import.meta.glob("/src/pages/articles/*.astro", {
  query: "?raw",
  import: "default",
  eager: true,
});

function field(src, name) {
  const m = src.match(new RegExp("const " + name + '\\s*=\\s*"((?:[^"\\\\]|\\\\.)*)"'));
  return m ? m[1].replace(/\\"/g, '"') : "";
}

const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const formatDate = (d) => {
  if (!d) return "";
  const [y, m, day] = d.split("-");
  return `${months[parseInt(m, 10) - 1]} ${parseInt(day, 10)}, ${y}`;
};

const articles = Object.entries(rawArticles)
  .map(([path, src]) => {
    const slug = path.split("/").pop().replace(/\.astro$/, "");
    const dateMatch = slug.match(/(\d{4}-\d{2}-\d{2})$/);
    return {
      slug,
      url: `/articles/${slug}.html`,
      title: field(src, "pageTitle") || slug,
      description: field(src, "pageDescription"),
      date: dateMatch ? dateMatch[1] : "",
    };
  })
  .sort((a, b) => (a.date < b.date ? 1 : a.date > b.date ? -1 : 0));
---

<main class="container-medium container-solution">
  <div class="solution-page-card">
    <h1 class="title h2-size">Articles &amp; Insights</h1>
    <p class="paragraph" style="max-width:680px;">
      Product deep-dives and guides from BWS on blockchain, AI-assisted development, and turning validated market
      demand into shipped products.
    </p>
    <div class="resources-article-grid">
      {
        articles.map((a) => (
          <a href={a.url} class="resources-article-card">
            {a.date && <span class="resources-article-date">{formatDate(a.date)}</span>}
            <h2 class="resources-article-title">{a.title}</h2>
            {a.description && <p class="resources-article-desc">{a.description}</p>}
            <span class="resources-article-readmore">
              Read article<i class="fa-solid fa-arrow-right" aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</main>

<style is:global>
  .resources-article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 18px;
    margin-top: 28px;
  }
  .resources-article-card {
    display: flex;
    flex-direction: column;
    padding: 22px;
    border: 1px solid rgba(17, 17, 26, 0.08);
    border-radius: 14px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      border-color 0.18s ease;
  }
  .resources-article-card:hover {
    transform: translateY(-3px);
    border-color: rgba(196, 24, 65, 0.35);
    box-shadow: 0 10px 28px rgba(17, 17, 26, 0.1);
  }
  .resources-article-date {
    font: 600 11px/1 ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(17, 17, 26, 0.5);
    margin-bottom: 10px;
  }
  .resources-article-title {
    margin: 0 0 10px;
    font-size: 17px;
    line-height: 1.35;
    font-weight: 700;
  }
  .resources-article-desc {
    margin: 0 0 16px;
    font-size: 14px;
    line-height: 1.5;
    color: rgba(17, 17, 26, 0.7);
  }
  .resources-article-readmore {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-top: auto;
    font-size: 13px;
    font-weight: 700;
    color: var(--rose, #c41841);
  }
</style>
