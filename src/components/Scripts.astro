<script
  src="/assets/js/jquery-3.5.1.min.dc5e7f18c8.js"
  type="text/javascript"
  integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0="
  crossorigin="anonymous"></script>
<script src="/assets/js/webflow.schunk.6d83011aa4f34449.js" type="text/javascript"></script>
<script src="/assets/js/webflow.schunk.1ad200ed633c14bf.js" type="text/javascript"></script>
<script src="/assets/js/webflow.schunk.4913f0d9ee368d76.js" type="text/javascript"></script>
<script src="/assets/js/webflow.00c81055.72e38c471fcb0085.js" type="text/javascript"></script>
<script is:inline>
  const cleanFilterButtons = function () {
    let buttons = document.getElementsByClassName("button-filter-solution");
    for (let i = 0; i < buttons.length; i++) {
      buttons[i].classList.remove("button-primary");
      buttons[i].classList.add("button-secondary");
    }
  };

  const setFilterButton = function (button) {
    button.classList.remove("button-secondary");
    button.classList.add("button-primary");
  };

  const setSolutionDisplay = function (display, category) {
    let allSolutions = document.getElementsByClassName("filter-solution-x");
    for (let i = 0; i < allSolutions.length; i++) {
      if (display === "none") {
        if (!allSolutions[i].classList.contains(category)) {
          allSolutions[i].parentElement.parentElement.parentElement.classList.add("fade");
          setTimeout(function () {
            allSolutions[i].parentElement.parentElement.parentElement.style.display = "none";
          }, 500);
        }
      } else {
        allSolutions[i].parentElement.parentElement.parentElement.style.display = "block";
        allSolutions[i].parentElement.parentElement.parentElement.classList.remove("fade");
      }
    }
  };

  window.addEventListener("load", (event) => {
    const buttons = document.getElementsByClassName("button-filter-solution");
    for (let i = 0; i < buttons.length; i++) {
      buttons[i].addEventListener("click", (event) => {
        let allSolutions = document.getElementsByClassName("filter-solution-x");
        let category = buttons[i].getAttribute("data-category");
        let categorySolutions = document.getElementsByClassName("filter-solution-" + category);
        if (buttons[i].classList.contains("button-secondary")) {
          // select filter
          cleanFilterButtons();
          setSolutionDisplay("none", category);
          setFilterButton(buttons[i]);
          // we show category solutions
          setTimeout(function () {
            for (let i = 0; i < categorySolutions.length; i++) {
              categorySolutions[i].parentElement.parentElement.parentElement.style.display = "block";
              categorySolutions[i].parentElement.parentElement.parentElement.classList.remove("fade");
            }
          }, 500);
        } else {
          // unselect any filter
          cleanFilterButtons();
          setSolutionDisplay("block");
        }
      });
    }
  });
</script>
