---
import type { SuccessStory } from '../../data/successStories';
import SuccessStoryComponent from './SuccessStory.astro';

interface Props {
  stories: SuccessStory[];
}

const { stories } = Astro.props;
const storyCount = stories.length;
---

{
  storyCount > 1 ? (
    // Multiple stories - use Swiper carousel
    <>
      <div class="swiper success-stories-carousel">
        <div class="swiper-wrapper">
          {stories.map((story) => (
            <div class="swiper-slide">
              <SuccessStoryComponent story={story} />
            </div>
          ))}
        </div>
        <!-- Custom navigation buttons -->
        <button class="carousel-prev-btn" aria-label="Previous slide">‹</button>
        <button class="carousel-next-btn" aria-label="Next slide">›</button>
      </div>

      <script define:vars={{ storyCount }}>
        // Initialize Swiper carousel when DOM is loaded
        document.addEventListener('DOMContentLoaded', function () {
          // @ts-ignore - Swiper is loaded via CDN
          if (typeof Swiper !== 'undefined') {
            // @ts-ignore
            const swiper = new Swiper('.success-stories-carousel', {
              slidesPerView: 1,
              spaceBetween: 0,
              centeredSlides: true,
              loop: true,
              watchOverflow: true,
              autoplay: {
                delay: 8000, // 8 seconds (longer than news carousel)
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
              },
              breakpoints: {
                0: {
                  slidesPerView: 1,
                  spaceBetween: 0,
                },
              },
            });

            // Connect custom navigation buttons
            const prevBtn = document.querySelector('.carousel-prev-btn');
            const nextBtn = document.querySelector('.carousel-next-btn');

            if (prevBtn) {
              prevBtn.addEventListener('click', function() {
                swiper.slidePrev();
              });
            }

            if (nextBtn) {
              nextBtn.addEventListener('click', function() {
                swiper.slideNext();
              });
            }
          }
        });
      </script>

      <style>
        .success-stories-carousel {
          width: 100%;
          padding: 0 0 3rem 0;
          min-height: 400px;
          overflow: hidden;
          position: relative;
        }

        /* Swiper wrapper - ensure no overflow */
        .success-stories-carousel .swiper-wrapper {
          align-items: stretch;
        }

        /* Swiper slide styling */
        .success-stories-carousel .swiper-slide {
          display: flex;
          justify-content: center;
          height: auto;
          width: 100%;
          flex-shrink: 0;
        }

        /* Ensure slide content takes full width */
        .success-stories-carousel .swiper-slide > * {
          width: 100%;
          max-width: 100%;
        }

        /* Hide default Swiper navigation arrows */
        .success-stories-carousel .swiper-button-next,
        .success-stories-carousel .swiper-button-prev {
          display: none;
        }

        /* Hide pagination dots */
        .success-stories-carousel .swiper-pagination {
          display: none !important;
        }

        /* Custom navigation buttons */
        .carousel-prev-btn,
        .carousel-next-btn {
          position: absolute;
          bottom: 1rem;
          width: 1.25rem;
          height: 1.25rem;
          border-radius: 50%;
          background: rgba(255, 255, 255, 0.9);
          border: 1px solid #e91e63;
          color: #e91e63;
          font-size: 1rem;
          font-weight: bold;
          line-height: 1;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
          z-index: 10;
          transition: all 0.3s ease;
          padding: 0;
        }

        .carousel-prev-btn {
          right: 2.75rem;
        }

        .carousel-next-btn {
          right: 1rem;
        }

        .carousel-prev-btn:hover,
        .carousel-next-btn:hover {
          background: #e91e63;
          color: white;
          transform: scale(1.1);
        }

        .carousel-prev-btn:active,
        .carousel-next-btn:active {
          transform: scale(0.95);
        }

        /* Mobile adjustments */
        @media screen and (max-width: 479px) {
          .carousel-prev-btn,
          .carousel-next-btn {
            width: 1rem;
            height: 1rem;
            font-size: 0.75rem;
            bottom: 0.5rem;
          }

          .carousel-prev-btn {
            right: 2rem;
          }

          .carousel-next-btn {
            right: 0.5rem;
          }
        }
      </style>
    </>
  ) : (
    // Single story - no carousel, just display it
    <SuccessStoryComponent story={stories[0]} />
  )
}
