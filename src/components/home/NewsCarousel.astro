---
import type { NewsItem } from '../../data/news';
import NewsItemComponent from './NewsItem.astro';

interface Props {
  news: NewsItem[];
}

const { news } = Astro.props;
---

<div class="swiper news-carousel">
  <div class="swiper-wrapper">
    {
      news.map((item) => (
        <div class="swiper-slide">
          <NewsItemComponent news={item} />
        </div>
      ))
    }
  </div>
  <!-- Navigation arrows -->
  <div class="swiper-button-next"></div>
  <div class="swiper-button-prev"></div>
  <!-- Pagination -->
  <div class="swiper-pagination"></div>
</div>

<script define:vars={{ newsCount: news.length }}>
  // Initialize Swiper carousel when DOM is loaded
  document.addEventListener('DOMContentLoaded', function () {
    // @ts-ignore - Swiper is loaded via CDN
    if (typeof Swiper !== 'undefined') {
      // @ts-ignore
      new Swiper('.news-carousel', {
        slidesPerView: 2,
        spaceBetween: 16,
        loop: true,
        autoplay: newsCount > 2 ? {
          delay: 5000,
          disableOnInteraction: false,
          pauseOnMouseEnter: true,
        } : false,
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        breakpoints: {
          // Mobile: 1 slide
          320: {
            slidesPerView: 1,
            spaceBetween: 16,
          },
          // Desktop: 2 slides
          992: {
            slidesPerView: 2,
            spaceBetween: 16,
          },
        },
      });
    }
  });
</script>

<style>
  /* Override parent container width constraint for carousel */
  .section-token-launch .landing-page-content {
    max-width: 100% !important; /* Remove 940px constraint */
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .news-carousel {
    width: 100%;
    max-width: 960px; /* Fit 2 cards comfortably with gap and padding */
    margin: 0 auto; /* Center the carousel */
    padding: 0 1rem 3rem 1rem; /* Add padding for controls */
    min-height: 580px; /* Ensure enough height for full card visibility */
  }

  /* Swiper slide styling */
  .swiper-slide {
    display: flex;
    justify-content: center;
    height: auto; /* Allow content to determine height */
  }

  /* Card width constraint */
  .news-carousel .announcement-box {
    width: 440px !important;
    max-width: 440px;
    min-width: 380px;
  }

  /* Customize Swiper navigation arrows */
  .news-carousel .swiper-button-next,
  .news-carousel .swiper-button-prev {
    background: rgba(255, 255, 255, 0.8);
    border-radius: 50%;
    width: 3rem;
    height: 3rem;
    color: #333;
  }

  .news-carousel .swiper-button-next:hover,
  .news-carousel .swiper-button-prev:hover {
    background: rgba(255, 255, 255, 1);
  }

  .news-carousel .swiper-button-next::after,
  .news-carousel .swiper-button-prev::after {
    font-size: 1.5rem;
    font-weight: bold;
  }

  /* Customize pagination dots */
  .news-carousel .swiper-pagination {
    bottom: 0;
  }

  .news-carousel .swiper-pagination-bullet {
    background: rgba(255, 255, 255, 0.5);
    width: 12px;
    height: 12px;
    opacity: 1;
  }

  .news-carousel .swiper-pagination-bullet-active {
    background: #fff;
    transform: scale(1.2);
  }

  /* Responsive adjustments */
  @media screen and (max-width: 991px) {
    .news-carousel {
      max-width: 100%;
    }

    .news-carousel .announcement-box {
      width: 100% !important;
      max-width: 500px;
      min-width: 320px;
    }
  }
</style>
