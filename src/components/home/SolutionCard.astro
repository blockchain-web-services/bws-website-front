---
import type { Solution } from '../../data/solutions';

interface Props {
  solution: Solution;
}

const { solution} = Astro.props;
---

<div role="listitem" class="markeplace-collection-item w-dyn-item">
  {
    solution.networks.length > 0 && (
      <div class="networks-solution w-dyn-list">
        <div role="list" class="collection-list-2 w-dyn-items">
          {solution.networks.map((network) => (
            <div role="listitem" class="collection-item-2 w-dyn-item">
              <div
                style={`background-color:${network.color};border-color:${network.color}`}
                class="div-solution-network"
              >
                <div class="text-block-8">{network.name}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }
  <a href={solution.url} class="home-solution-card w-inline-block">
    <div class="w-embed">
      <span class={`filter-solution-x filter-solution-${solution.category}`}
      ></span>
    </div>
    <div class="solution-card-wrapper">
      <div class="home-solution-card-image">
        {solution.graphic ? (
          <div
            class={`home-solution-card-graphic pattern-${solution.graphic.pattern ?? 'dots'}`}
            role="img"
            aria-label={solution.graphic.alt}
            style={`--card-grad-from: ${solution.graphic.gradient[0]}; --card-grad-to: ${solution.graphic.gradient[1]}; --card-icon-color: ${solution.graphic.iconColor ?? '#ffffff'};`}
          >
            <i class={solution.graphic.icon} aria-hidden="true"></i>
          </div>
        ) : solution.image ? (
          <img
            src={solution.image.src}
            alt={solution.image.alt}
            sizes={solution.image.sizes}
            srcset={solution.image.srcset}
            class="image solution-card-image"
          />
        ) : null}
      </div>
      <div class="solution-card-content-wrapper">
        <div class="solution-card-2-column-title">
          <div class="solution-card-icon-wrapper">
            <div class="solution-card-icon"></div>
          </div>
          <div class="solution-card-title-wrapper">
            <h3 class="solution-card-title">{solution.title}</h3>
            <div class="solution-card-author">{solution.author}</div>
          </div>
        </div>
        <div class="solution-card-text">
          <h3 class="title h4-size blog-card-summary">
            {solution.description}
          </h3>
        </div>
        <div class="solution-card-read-more-text">
          Read more<span class="button-arrow"></span>
        </div>
      </div>
    </div>
  </a>
</div>

<style is:global>
  /* Graphic variant — CSS gradient + dotted pattern + centered Font Awesome icon.
     Sized to match the raster .solution-card-image (100% wide, 200px tall). */
  .home-solution-card-graphic {
    position: relative;
    width: 100%;
    height: 200px;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    background: linear-gradient(135deg, var(--card-grad-from, #25D366) 0%, var(--card-grad-to, #1a1b1e) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }

  .home-solution-card-graphic::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .home-solution-card-graphic.pattern-dots::before {
    background-image: radial-gradient(rgba(255, 255, 255, 0.18) 1.4px, transparent 1.6px);
    background-size: 18px 18px;
    background-position: 0 0;
  }

  .home-solution-card-graphic.pattern-mesh::before {
    background:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.22), transparent 45%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.14), transparent 50%);
  }

  .home-solution-card-graphic > i {
    position: relative;
    z-index: 1;
    color: var(--card-icon-color, #ffffff);
    font-size: 96px;
    line-height: 1;
    filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.25));
  }

  @media screen and (max-width: 767px) {
    .home-solution-card-graphic > i {
      font-size: 80px;
    }
  }
</style>
