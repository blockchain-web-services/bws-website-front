---
import type { MarketplaceAnnouncement } from '../../data/marketplaceAnnouncements';

interface Props {
  announcement: MarketplaceAnnouncement;
}

const { announcement } = Astro.props;
---

<div class="w-layout-vflex flex-ngc-announcement">
  <div class="w-layout-vflex flex-block-13">
    <div class="text-block-38">{announcement.title}</div>
    {
      announcement.descriptions.map((desc) => (
        <div class="text-block-39">
          {desc}
          <br />
        </div>
      ))
    }
    {
      announcement.image && (
        <img
          src={announcement.image.src}
          loading={announcement.image.loading}
          sizes={announcement.image.sizes}
          srcset={announcement.image.srcset}
          alt={announcement.image.alt}
        />
      )
    }
    <a
      href={announcement.button.href}
      target={announcement.button.target}
      class="button-secondary tokenomics button-small w-button"
    >
      {announcement.button.text}
      {announcement.button.hasArrow && <span class="button-arrow" />}
    </a>
  </div>
  {
    announcement.video && (
      <div class="w-layout-vflex flex-block-14">
        <div
          style={`padding-top:${announcement.video.paddingTop}`}
          class="video w-video w-embed"
        >
          <iframe
            src={announcement.video.embedUrl}
            width={announcement.video.width}
            height={announcement.video.height}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title={announcement.video.title}
          />
        </div>
        {announcement.link && (
          <a
            href={announcement.link.href}
            target={announcement.link.target}
            class="link-block-3 w-inline-block"
          >
            <div class="text-block-42">
              {announcement.link.text} <br />
              {announcement.link.highlightedText && (
                <span class="text-span-10">
                  {announcement.link.highlightedText}
                </span>
              )}
            </div>
          </a>
        )}
      </div>
    )
  }
</div>
