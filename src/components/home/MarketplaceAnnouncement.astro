---
import type { MarketplaceAnnouncement } from '../../data/marketplaceAnnouncements';

interface Props {
  announcement: MarketplaceAnnouncement;
}

const { announcement } = Astro.props;

// Determine if we should use two-column layout (when video exists)
const hasTwoColumns = !!announcement.video;

// Collect all images (single or multiple)
const allImages = announcement.images || (announcement.image ? [announcement.image] : []);

// Collect all buttons (single or multiple)
const allButtons = announcement.buttons || (announcement.button ? [announcement.button] : []);
---

<div class={`w-layout-vflex flex-ngc-announcement ${hasTwoColumns ? 'two-column' : 'single-column'}`}>
  <!-- Left column: Main content -->
  <div class="w-layout-vflex flex-block-13">
    <!-- Title (mandatory) -->
    <div class="text-block-38">{announcement.title}</div>

    <!-- Descriptions (mandatory, can be multiple) -->
    {
      announcement.descriptions.map((desc) => (
        <div class="text-block-39">
          {desc}
          <br />
        </div>
      ))
    }

    <!-- Images (optional, can be multiple) -->
    {
      allImages.map((image) => (
        <img
          src={image.src}
          loading={image.loading || 'lazy'}
          sizes={image.sizes}
          srcset={image.srcset}
          alt={image.alt}
        />
      ))
    }

    <!-- Buttons (optional, can be multiple) -->
    {
      allButtons.map((button) => (
        <a
          href={button.href}
          target={button.target}
          class="button-secondary tokenomics button-small w-button"
        >
          {button.text}
          {button.hasArrow && <span class="button-arrow" />}
        </a>
      ))
    }
  </div>

  <!-- Right column: Video (optional, only if video exists) -->
  {
    announcement.video && (
      <div class="w-layout-vflex flex-block-14">
        <div
          style={`padding-top:${announcement.video.paddingTop}`}
          class="video w-video w-embed"
        >
          <iframe
            src={announcement.video.embedUrl}
            width={announcement.video.width}
            height={announcement.video.height}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title={announcement.video.title}
          />
        </div>
        {announcement.link && (
          <a
            href={announcement.link.href}
            target={announcement.link.target}
            class="link-block-3 w-inline-block"
          >
            <div class="text-block-42">
              {announcement.link.text} <br />
              {announcement.link.highlightedText && (
                <span class="text-span-10">
                  {announcement.link.highlightedText}
                </span>
              )}
            </div>
          </a>
        )}
      </div>
    )
  }
</div>
