---
// Emits SoftwareApplication + BreadcrumbList JSON-LD for a marketplace product.
export interface Props {
  name: string;
  description: string;
  path: string; // canonical path of the detail page, e.g. /marketplace/wallawhats.html
  category?: string; // schema.org applicationCategory
  externalUrl?: string; // the product's own site, if any
  offers?: { name: string; price: string; desc?: string }[];
}

const { name, description, path, category = "BusinessApplication", externalUrl, offers } = Astro.props;
const site = Astro.site ?? new URL("https://www.bws.ninja");
const pageUrl = new URL(path.replace(/\.html$/, ""), site).href;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      name,
      applicationCategory: category,
      operatingSystem: "Web",
      url: externalUrl ?? pageUrl,
      description,
      ...(offers && offers.length
        ? {
            offers: offers.map((o) => ({
              "@type": "Offer",
              name: o.name,
              price: o.price,
              priceCurrency: "USD",
              ...(o.desc ? { description: o.desc } : {}),
            })),
          }
        : {}),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: site.origin + "/" },
        { "@type": "ListItem", position: 2, name: "Marketplace", item: site.origin + "/#solutions" },
        { "@type": "ListItem", position: 3, name, item: pageUrl },
      ],
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
