---
// Main content for contact-us page
---

<section class="contact-section">
  <div class="w-layout-blockcontainer container-full w-container">
    <div class="contact-content-wrapper">
      <div class="contact-header">
        <h1 class="contact-title">Get in touch</h1>
        <div class="contact-subtitle">Need help to start your journey?</div>
      </div>

      <div class="contact-main">
        <div class="contact-description">
          <p>Fill out the form and let's explore how blockchain can revolutionize your business operations.</p>
        </div>
       
          <script type="module" src="https://interfaces.zapier.com/assets/web-components/zapier-interfaces/zapier-interfaces.esm.js"></script>
                      <zapier-interfaces-page-embed
                        page-id="cmbg4e0o9004t102u2n3bk5iy"
                        no-background="true"
                        style="max-width: 900px; height: 800px"></zapier-interfaces-page-embed>

        <div class="contact-alternative">
          <p>
            You can also contact by email: <a href="mailto:info@bws.ninja" class="contact-email-link">info@bws.ninja</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 80px 0;
    min-height: 60vh;
  }

  .contact-content-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .contact-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .contact-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a1a1a;
  }

  .contact-subtitle {
    font-size: 24px;
    color: #666;
  }

  .contact-description {
    margin-bottom: 40px;
    text-align: center;
  }

  .contact-description p {
    margin-bottom: 15px;
    font-size: 18px;
    line-height: 1.6;
    color: #333;
  }

  .contact-form-wrapper {
    background: #f8f9fa;
    padding: 40px;
    border-radius: 8px;
    margin-bottom: 40px;
  }

  .form-group {
    margin-bottom: 25px;
  }

  .form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    color: #333;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
    transition: border-color 0.3s;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #0066cc;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-alternative {
    text-align: center;
    font-size: 16px;
    color: #666;
  }

  .contact-email-link {
    color: #0066cc;
    text-decoration: none;
  }

  .contact-email-link:hover {
    text-decoration: underline;
  }
</style>
