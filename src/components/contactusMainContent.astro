---
// Main content for contact-us page
---

<section class="contact-section">
  <div class="w-layout-blockcontainer container-full w-container">
    <div class="contact-content-wrapper">
      <div class="contact-header">
        <h1 class="contact-title">Get in touch</h1>
        <div class="contact-subtitle">Need help to start your journey?</div>
      </div>

      <div class="contact-main">
        <div class="contact-description">
          <p>
            Whether you're in the planning stages or ready to implement, we have the expertise to guide you every step
            of the way.
          </p>
          <p>Fill out the form and let's explore how blockchain can revolutionize your business operations.</p>
        </div>

        <div class="contact-form-wrapper">
          <form action="https://prod.bws.ninja/api/contact" method="POST" class="contact-form">
            <div class="form-group">
              <label for="name" class="form-label">Name</label>
              <input type="text" id="name" name="name" required class="form-input w-input" />
            </div>

            <div class="form-group">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" required class="form-input w-input" />
            </div>

            <div class="form-group">
              <label for="company" class="form-label">Company</label>
              <input type="text" id="company" name="company" class="form-input w-input" />
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="message" required class="form-textarea w-input" rows="4"></textarea>
            </div>

            <button type="submit" class="button-primary w-button">Send Message</button>
          </form>
        </div>

        <div class="contact-alternative">
          <p>
            You can also contact by email: <a href="mailto:info@bws.ninja" class="contact-email-link">info@bws.ninja</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 80px 0;
    min-height: 60vh;
  }

  .contact-content-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .contact-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .contact-title {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a1a1a;
  }

  .contact-subtitle {
    font-size: 24px;
    color: #666;
  }

  .contact-description {
    margin-bottom: 40px;
    text-align: center;
  }

  .contact-description p {
    margin-bottom: 15px;
    font-size: 18px;
    line-height: 1.6;
    color: #333;
  }

  .contact-form-wrapper {
    background: #f8f9fa;
    padding: 40px;
    border-radius: 8px;
    margin-bottom: 40px;
  }

  .form-group {
    margin-bottom: 25px;
  }

  .form-label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    color: #333;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
    transition: border-color 0.3s;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #0066cc;
  }

  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-alternative {
    text-align: center;
    font-size: 16px;
    color: #666;
  }

  .contact-email-link {
    color: #0066cc;
    text-decoration: none;
  }

  .contact-email-link:hover {
    text-decoration: underline;
  }
</style>
