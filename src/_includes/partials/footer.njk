<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-section">
        <div class="footer-brand">
          <img src="/assets/images/logo-256x256.png" alt="{{ site.name }}" width="60" height="60">
          <p class="footer-tagline">Cutting-Edge Blockchain Solutions</p>
        </div>
        
        <div class="footer-social">
          {% for social in navigation.footer.social %}
            <a href="{{ social.url }}" target="_blank" rel="noopener noreferrer" 
               aria-label="{{ social.title }}" class="social-link">
              <i class="icon-{{ social.icon }}"></i>
            </a>
          {% endfor %}
        </div>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Solutions</h3>
        <ul class="footer-links">
          {% for solution in navigation.footer.solutions %}
            <li><a href="{{ solution.url }}">{{ solution.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Company</h3>
        <ul class="footer-links">
          {% for link in navigation.footer.company %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer-section">
        <h3 class="footer-title">Legal</h3>
        <ul class="footer-links">
          {% for link in navigation.footer.legal %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">
        &copy; 2024 {{ site.name }}. All rights reserved.
      </p>
    </div>
  </div>
</footer>