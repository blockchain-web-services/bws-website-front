{# Testimonial Card Component #}
<div class="testimonial-card">
  {% if testimonial.rating %}
    <div class="testimonial-card__rating">
      {% for i in range(testimonial.rating) %}
        <i class="icon-star-filled"></i>
      {% endfor %}
      {% for i in range(5 - testimonial.rating) %}
        <i class="icon-star"></i>
      {% endfor %}
    </div>
  {% endif %}

  <blockquote class="testimonial-card__quote">
    <p>"{{ testimonial.quote }}"</p>
  </blockquote>

  <div class="testimonial-card__author">
    {% if testimonial.avatar %}
      <img src="{{ testimonial.avatar }}"
           alt="{{ testimonial.author }}"
           class="testimonial-card__avatar"
           loading="lazy">
    {% endif %}

    <div class="testimonial-card__author-info">
      <cite class="testimonial-card__name">{{ testimonial.author }}</cite>
      {% if testimonial.role %}
        <span class="testimonial-card__role">{{ testimonial.role }}</span>
      {% endif %}
      {% if testimonial.company %}
        <span class="testimonial-card__company">{{ testimonial.company }}</span>
      {% endif %}
    </div>
  </div>

  {% if testimonial.logo %}
    <img src="{{ testimonial.logo }}"
         alt="{{ testimonial.company }}"
         class="testimonial-card__logo"
         loading="lazy">
  {% endif %}
</div>