{# Hero Section Component #}
<section class="hero {% if hero.variant %}hero--{{ hero.variant }}{% endif %} {% if hero.className %}{{ hero.className }}{% endif %}">
  <div class="hero-container">
    {% if hero.backgroundImage %}
      <div class="hero-background" style="background-image: url('{{ hero.backgroundImage }}')"></div>
    {% endif %}

    {% if hero.backgroundVideo %}
      <video class="hero-video" autoplay muted loop playsinline>
        <source src="{{ hero.backgroundVideo }}" type="video/mp4">
      </video>
    {% endif %}

    <div class="hero-content {% if hero.contentAlign %}hero-content--{{ hero.contentAlign }}{% endif %}">
      {% if hero.badge %}
        <span class="hero-badge">{{ hero.badge }}</span>
      {% endif %}

      {% if hero.title %}
        <h1 class="hero-title {% if hero.titleSize %}hero-title--{{ hero.titleSize }}{% endif %}">
          {{ hero.title }}
        </h1>
      {% endif %}

      {% if hero.subtitle %}
        <p class="hero-subtitle">{{ hero.subtitle }}</p>
      {% endif %}

      {% if hero.description %}
        <p class="hero-description">{{ hero.description }}</p>
      {% endif %}

      {% if hero.ctaPrimary or hero.ctaSecondary %}
        <div class="hero-actions">
          {% if hero.ctaPrimary %}
            <a href="{{ hero.ctaPrimary.href }}"
               class="btn btn-primary {% if hero.ctaPrimary.size %}btn-{{ hero.ctaPrimary.size }}{% else %}btn-large{% endif %}"
               {% if hero.ctaPrimary.target %}target="{{ hero.ctaPrimary.target }}"{% endif %}
               {% if hero.ctaPrimary.analytics %}data-analytics="{{ hero.ctaPrimary.analytics }}"{% endif %}>
              {% if hero.ctaPrimary.icon %}
                <i class="icon-{{ hero.ctaPrimary.icon }}"></i>
              {% endif %}
              <span>{{ hero.ctaPrimary.text }}</span>
            </a>
          {% endif %}

          {% if hero.ctaSecondary %}
            <a href="{{ hero.ctaSecondary.href }}"
               class="btn btn-secondary {% if hero.ctaSecondary.size %}btn-{{ hero.ctaSecondary.size }}{% else %}btn-large{% endif %}"
               {% if hero.ctaSecondary.target %}target="{{ hero.ctaSecondary.target }}"{% endif %}
               {% if hero.ctaSecondary.analytics %}data-analytics="{{ hero.ctaSecondary.analytics }}"{% endif %}>
              {% if hero.ctaSecondary.icon %}
                <i class="icon-{{ hero.ctaSecondary.icon }}"></i>
              {% endif %}
              <span>{{ hero.ctaSecondary.text }}</span>
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if hero.features %}
        <ul class="hero-features">
          {% for feature in hero.features %}
            <li class="hero-feature">
              {% if feature.icon %}
                <i class="icon-{{ feature.icon }}"></i>
              {% endif %}
              <span>{{ feature.text or feature }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if hero.trustedBy %}
        <div class="hero-trusted-by">
          <p class="trusted-label">{{ hero.trustedBy.label or "Trusted by" }}</p>
          <div class="trusted-logos">
            {% for logo in hero.trustedBy.logos %}
              <img src="{{ logo.src }}" alt="{{ logo.alt }}" class="trusted-logo" loading="lazy">
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    {% if hero.image %}
      <div class="hero-image {% if hero.imagePosition %}hero-image--{{ hero.imagePosition }}{% endif %}">
        <img src="{{ hero.image.src }}"
             alt="{{ hero.image.alt or hero.title }}"
             {% if hero.image.width %}width="{{ hero.image.width }}"{% endif %}
             {% if hero.image.height %}height="{{ hero.image.height }}"{% endif %}
             loading="lazy">
      </div>
    {% endif %}

    {% if hero.scrollIndicator %}
      <div class="hero-scroll-indicator">
        <span>{{ hero.scrollIndicator.text or "Scroll to explore" }}</span>
        <i class="icon-chevron-down"></i>
      </div>
    {% endif %}
  </div>
</section>