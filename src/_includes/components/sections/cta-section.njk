{# Call-to-Action Section Component #}
<section class="cta-section {% if cta.variant %}cta-section--{{ cta.variant }}{% endif %} {% if cta.className %}{{ cta.className }}{% endif %}">
  <div class="cta-container">
    {% if cta.backgroundImage %}
      <div class="cta-background" style="background-image: url('{{ cta.backgroundImage }}')"></div>
    {% endif %}

    <div class="cta-content {% if cta.align %}cta-content--{{ cta.align }}{% endif %}">
      {% if cta.icon %}
        <div class="cta-icon">
          <i class="icon-{{ cta.icon }}"></i>
        </div>
      {% endif %}

      {% if cta.badge %}
        <span class="cta-badge">{{ cta.badge }}</span>
      {% endif %}

      {% if cta.title %}
        <h2 class="cta-title">{{ cta.title }}</h2>
      {% endif %}

      {% if cta.subtitle %}
        <p class="cta-subtitle">{{ cta.subtitle }}</p>
      {% endif %}

      {% if cta.description %}
        <p class="cta-description">{{ cta.description }}</p>
      {% endif %}

      {% if cta.features %}
        <ul class="cta-features">
          {% for feature in cta.features %}
            <li>
              <i class="icon-check"></i>
              {{ feature }}
            </li>
          {% endfor %}
        </ul>
      {% endif %}

      {% if cta.actions %}
        <div class="cta-actions">
          {% for action in cta.actions %}
            <a href="{{ action.href }}"
               class="btn {% if action.variant %}btn-{{ action.variant }}{% elif loop.first %}btn-primary{% else %}btn-secondary{% endif %} {% if action.size %}btn-{{ action.size }}{% else %}btn-large{% endif %}"
               {% if action.target %}target="{{ action.target }}"{% endif %}
               {% if action.analytics %}data-analytics="{{ action.analytics }}"{% endif %}>
              {% if action.icon %}
                <i class="icon-{{ action.icon }}"></i>
              {% endif %}
              <span>{{ action.text }}</span>
            </a>
          {% endfor %}
        </div>
      {% elif cta.primaryAction or cta.secondaryAction %}
        <div class="cta-actions">
          {% if cta.primaryAction %}
            <a href="{{ cta.primaryAction.href }}"
               class="btn btn-primary {% if cta.primaryAction.size %}btn-{{ cta.primaryAction.size }}{% else %}btn-large{% endif %}"
               {% if cta.primaryAction.target %}target="{{ cta.primaryAction.target }}"{% endif %}
               {% if cta.primaryAction.analytics %}data-analytics="{{ cta.primaryAction.analytics }}"{% endif %}>
              {% if cta.primaryAction.icon %}
                <i class="icon-{{ cta.primaryAction.icon }}"></i>
              {% endif %}
              <span>{{ cta.primaryAction.text }}</span>
            </a>
          {% endif %}

          {% if cta.secondaryAction %}
            <a href="{{ cta.secondaryAction.href }}"
               class="btn btn-secondary {% if cta.secondaryAction.size %}btn-{{ cta.secondaryAction.size }}{% else %}btn-large{% endif %}"
               {% if cta.secondaryAction.target %}target="{{ cta.secondaryAction.target }}"{% endif %}
               {% if cta.secondaryAction.analytics %}data-analytics="{{ cta.secondaryAction.analytics }}"{% endif %}>
              {% if cta.secondaryAction.icon %}
                <i class="icon-{{ cta.secondaryAction.icon }}"></i>
              {% endif %}
              <span>{{ cta.secondaryAction.text }}</span>
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if cta.form %}
        <form class="cta-form" action="{{ cta.form.action }}" method="{{ cta.form.method or 'POST' }}">
          <div class="form-group">
            {% if cta.form.fields %}
              {% for field in cta.form.fields %}
                <input type="{{ field.type or 'text' }}"
                       name="{{ field.name }}"
                       placeholder="{{ field.placeholder }}"
                       class="form-control"
                       {% if field.required %}required{% endif %}>
              {% endfor %}
            {% else %}
              <input type="email"
                     name="email"
                     placeholder="{{ cta.form.placeholder or 'Enter your email' }}"
                     class="form-control"
                     required>
            {% endif %}
            <button type="submit" class="btn btn-primary">
              {{ cta.form.submitText or "Submit" }}
            </button>
          </div>
          {% if cta.form.disclaimer %}
            <p class="form-disclaimer">{{ cta.form.disclaimer }}</p>
          {% endif %}
        </form>
      {% endif %}

      {% if cta.stats %}
        <div class="cta-stats">
          {% for stat in cta.stats %}
            <div class="stat-item">
              <span class="stat-value">{{ stat.value }}</span>
              <span class="stat-label">{{ stat.label }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}

      {% if cta.testimonial %}
        <blockquote class="cta-testimonial">
          <p>"{{ cta.testimonial.quote }}"</p>
          <cite>
            <span class="testimonial-author">{{ cta.testimonial.author }}</span>
            {% if cta.testimonial.role %}
              <span class="testimonial-role">{{ cta.testimonial.role }}</span>
            {% endif %}
            {% if cta.testimonial.company %}
              <span class="testimonial-company">{{ cta.testimonial.company }}</span>
            {% endif %}
          </cite>
        </blockquote>
      {% endif %}
    </div>

    {% if cta.image %}
      <div class="cta-image">
        <img src="{{ cta.image.src }}"
             alt="{{ cta.image.alt or cta.title }}"
             loading="lazy">
      </div>
    {% endif %}
  </div>
</section>