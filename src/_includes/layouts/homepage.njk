{% extends "layouts/base.njk" %}

{% block content %}
<div data-poster-url="https://cdn.prod.website-files.com/6474d385cfec71cb21a92251%2F670f916b2f60627d5201850b_shutterstock_1108417201-poster-00001.jpg" data-video-urls="https://cdn.prod.website-files.com/6474d385cfec71cb21a92251%2F670f916b2f60627d5201850b_shutterstock_1108417201-transcode.mp4,https://cdn.prod.website-files.com/6474d385cfec71cb21a92251%2F670f916b2f60627d5201850b_shutterstock_1108417201-transcode.webm" data-autoplay="true" data-loop="true" data-wf-ignore="true" class="background-lines-top w-background-video w-background-video-atom">
  <video autoplay="" loop="" muted="" playsinline="" data-wf-ignore="true" data-object-fit="cover">
    <source src="https://cdn.prod.website-files.com/6474d385cfec71cb21a92251%2F670f916b2f60627d5201850b_shutterstock_1108417201-transcode.mp4" data-wf-ignore="true"/>
    <source src="https://cdn.prod.website-files.com/6474d385cfec71cb21a92251%2F670f916b2f60627d5201850b_shutterstock_1108417201-transcode.webm" data-wf-ignore="true"/>
  </video>
</div>

<section class="hero-header">
  <div class="hero-header-wrapper">
    <div class="hero-header-main-content w-container">
      <h1 class="home-hero-heading">{{ hero.title }}</h1>
      <p class="hero-paragraph">{{ hero.subtitle }}</p>
      <div class="home-hero-button-wrapper">
        <a href="{{ hero.ctaPrimary.href }}" class="button-primary larger w-button">{{ hero.ctaPrimary.text }}</a>
        <a href="{{ hero.ctaSecondary.href }}" class="button-secondary larger w-button">{{ hero.ctaSecondary.text }}</a>
      </div>
    </div>
  </div>
</section>

<section id="solutions" class="solutions-section">
  <div class="container">
    <h2 class="section-title">Our Blockchain Solutions</h2>
    <p class="section-subtitle">Choose from our marketplace of cutting-edge blockchain solutions</p>
    
    <div class="solutions-grid">
      {% for solution in navigation.footer.solutions %}
        <div class="solution-card">
          <div class="solution-icon">
            <i class="icon-blockchain"></i>
          </div>
          <h3 class="solution-title">{{ solution.title }}</h3>
          <a href="{{ solution.url }}" class="solution-link">
            Learn More →
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="features-section">
  <div class="container">
    <h2 class="section-title">Why Choose BWS?</h2>
    
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <i class="icon-shield"></i>
        </div>
        <h3>Enterprise Security</h3>
        <p>Bank-grade security with advanced encryption and multi-signature wallets</p>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <i class="icon-lightning"></i>
        </div>
        <h3>Lightning Fast</h3>
        <p>High-performance blockchain solutions with minimal latency</p>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <i class="icon-scale"></i>
        </div>
        <h3>Infinitely Scalable</h3>
        <p>Solutions that grow with your business needs</p>
      </div>
    </div>
  </div>
</section>

<section class="industries-section">
  <div class="container">
    <h2 class="section-title">Industries We Serve</h2>
    
    <div class="industries-grid">
      {% for industry in navigation.main[2].children %}
        <div class="industry-card">
          <h3>{{ industry.title }}</h3>
          <a href="{{ industry.url }}" class="industry-link">Explore →</a>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <div class="cta-content">
      <h2>Ready to Transform Your Business?</h2>
      <p>Join thousands of companies using BWS blockchain solutions</p>
      <a href="/contact-us.html" class="btn btn-primary btn-large">
        Get Started Today
      </a>
    </div>
  </div>
</section>
{% endblock %}