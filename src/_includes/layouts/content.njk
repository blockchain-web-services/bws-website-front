---
layout: layouts/base.njk
---

{# Content page template for articles, blog posts, and text-heavy pages #}

{% block containerClass %}container container--narrow{% endblock %}

{% block breadcrumbs %}
  {% if breadcrumbs or category %}
    {% include "partials/breadcrumbs.njk" %}
  {% endif %}
{% endblock %}

{% block content %}
  <article class="article-content" itemscope itemtype="http://schema.org/Article">
    <header class="article-header">
      {% if category %}
        <div class="article-category">
          <a href="/{{ category.slug }}/">{{ category.name }}</a>
        </div>
      {% endif %}

      <h1 class="article-title" itemprop="headline">{{ title }}</h1>

      {% if subtitle or excerpt %}
        <p class="article-subtitle" itemprop="description">{{ subtitle or excerpt }}</p>
      {% endif %}

      <div class="article-meta">
        {% if author %}
          <span class="article-author" itemprop="author" itemscope itemtype="http://schema.org/Person">
            By <span itemprop="name">{{ author.name or author }}</span>
          </span>
        {% endif %}

        {% if date %}
          <time class="article-date" datetime="{{ date | htmlDateString }}" itemprop="datePublished">
            {{ date | dateFormat }}
          </time>
        {% endif %}

        {% if readingTime %}
          <span class="article-reading-time">{{ readingTime }} min read</span>
        {% endif %}
      </div>

      {% if featuredImage %}
        <figure class="article-featured-image">
          <img src="{{ featuredImage.url }}"
               alt="{{ featuredImage.alt or title }}"
               itemprop="image"
               loading="lazy">
          {% if featuredImage.caption %}
            <figcaption>{{ featuredImage.caption }}</figcaption>
          {% endif %}
        </figure>
      {% endif %}
    </header>

    <div class="article-body" itemprop="articleBody">
      {# Table of Contents #}
      {% if toc or showToc %}
        <aside class="article-toc">
          <h2 class="toc-title">Table of Contents</h2>
          <nav class="toc-nav">
            {{ content | toc | safe }}
          </nav>
        </aside>
      {% endif %}

      {# Main Content #}
      <div class="article-content-body">
        {{ content | safe }}
      </div>
    </div>

    <footer class="article-footer">
      {% if tags %}
        <div class="article-tags">
          <span class="tags-label">Tags:</span>
          {% for tag in tags %}
            <a href="/tags/{{ tag | slug }}/" class="tag-link" rel="tag">{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}

      {% if socialShare != false %}
        <div class="article-share">
          <span class="share-label">Share:</span>
          <div class="share-buttons">
            <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ site.url }}{{ page.url | urlencode }}"
               target="_blank" rel="noopener" class="share-button share-twitter">
              <i class="icon-twitter"></i> Twitter
            </a>
            <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ site.url }}{{ page.url | urlencode }}"
               target="_blank" rel="noopener" class="share-button share-linkedin">
              <i class="icon-linkedin"></i> LinkedIn
            </a>
            <a href="mailto:?subject={{ title | urlencode }}&body={{ site.url }}{{ page.url | urlencode }}"
               class="share-button share-email">
              <i class="icon-email"></i> Email
            </a>
          </div>
        </div>
      {% endif %}
    </footer>

    {# Related Articles #}
    {% if relatedArticles %}
      <section class="related-articles">
        <h2 class="related-title">Related Articles</h2>
        <div class="related-grid">
          {% for article in relatedArticles %}
            {% include "components/cards/article-card.njk" %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  </article>
{% endblock %}

{% block ctaSection %}
  {% if cta %}
    {% include "components/sections/cta-section.njk" %}
  {% elif newsletter != false %}
    <section class="newsletter-section">
      <div class="section-container">
        <h2>Stay Updated</h2>
        <p>Get the latest blockchain insights delivered to your inbox.</p>
        {% include "components/forms/newsletter-form.njk" %}
      </div>
    </section>
  {% endif %}
{% endblock %}