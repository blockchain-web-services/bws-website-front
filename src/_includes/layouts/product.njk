---
layout: layouts/base.njk
---

{# Product/Solution page template for showcasing products and services #}

{% block hero %}
  <section class="product-hero">
    <div class="hero-container">
      <div class="hero-content">
        {% if badge %}
          <span class="product-badge">{{ badge }}</span>
        {% endif %}

        <h1 class="product-title">{{ title }}</h1>

        {% if tagline %}
          <p class="product-tagline">{{ tagline }}</p>
        {% endif %}

        {% if description %}
          <p class="product-description">{{ description }}</p>
        {% endif %}

        <div class="hero-actions">
          {% if primaryAction %}
            <a href="{{ primaryAction.url }}" class="btn btn-primary btn-large">
              {% if primaryAction.icon %}
                <i class="icon-{{ primaryAction.icon }}"></i>
              {% endif %}
              {{ primaryAction.text }}
            </a>
          {% endif %}

          {% if secondaryAction %}
            <a href="{{ secondaryAction.url }}" class="btn btn-secondary btn-large">
              {{ secondaryAction.text }}
            </a>
          {% endif %}
        </div>

        {% if highlights %}
          <ul class="product-highlights">
            {% for highlight in highlights %}
              <li>
                <i class="icon-check"></i>
                {{ highlight }}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      {% if heroImage %}
        <div class="hero-image">
          <img src="{{ heroImage.url }}"
               alt="{{ heroImage.alt or title }}"
               loading="lazy">
        </div>
      {% endif %}
    </div>
  </section>
{% endblock %}

{% block content %}
  {# Key Features #}
  {% if features %}
    <section class="product-features">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ features.title or "Key Features" }}</h2>
          {% if features.subtitle %}
            <p>{{ features.subtitle }}</p>
          {% endif %}
        </div>

        <div class="features-grid {% if features.layout %}features-grid--{{ features.layout }}{% endif %}">
          {% for feature in features.items %}
            <div class="feature-card">
              {% if feature.icon %}
                <div class="feature-icon">
                  <i class="icon-{{ feature.icon }}"></i>
                </div>
              {% endif %}
              {% if feature.image %}
                <img src="{{ feature.image }}" alt="{{ feature.title }}" class="feature-image">
              {% endif %}
              <h3 class="feature-title">{{ feature.title }}</h3>
              <p class="feature-description">{{ feature.description }}</p>
              {% if feature.link %}
                <a href="{{ feature.link.url }}" class="feature-link">
                  {{ feature.link.text }} →
                </a>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# How It Works #}
  {% if howItWorks %}
    <section class="how-it-works">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ howItWorks.title or "How It Works" }}</h2>
          {% if howItWorks.subtitle %}
            <p>{{ howItWorks.subtitle }}</p>
          {% endif %}
        </div>

        <div class="process-steps">
          {% for step in howItWorks.steps %}
            <div class="process-step">
              <div class="step-number">{{ loop.index }}</div>
              <h3 class="step-title">{{ step.title }}</h3>
              <p class="step-description">{{ step.description }}</p>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Use Cases #}
  {% if useCases %}
    <section class="use-cases">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ useCases.title or "Use Cases" }}</h2>
          {% if useCases.subtitle %}
            <p>{{ useCases.subtitle }}</p>
          {% endif %}
        </div>

        <div class="use-cases-grid">
          {% for useCase in useCases.items %}
            <div class="use-case-card">
              {% if useCase.industry %}
                <span class="use-case-industry">{{ useCase.industry }}</span>
              {% endif %}
              <h3>{{ useCase.title }}</h3>
              <p>{{ useCase.description }}</p>
              {% if useCase.benefits %}
                <ul class="use-case-benefits">
                  {% for benefit in useCase.benefits %}
                    <li>{{ benefit }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Pricing #}
  {% if pricing %}
    <section class="pricing-section">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ pricing.title or "Pricing" }}</h2>
          {% if pricing.subtitle %}
            <p>{{ pricing.subtitle }}</p>
          {% endif %}
        </div>

        <div class="pricing-plans">
          {% for plan in pricing.plans %}
            <div class="pricing-card {% if plan.featured %}pricing-card--featured{% endif %}">
              {% if plan.badge %}
                <span class="plan-badge">{{ plan.badge }}</span>
              {% endif %}
              <h3 class="plan-name">{{ plan.name }}</h3>
              <div class="plan-price">
                <span class="price-amount">{{ plan.price }}</span>
                {% if plan.period %}
                  <span class="price-period">/{{ plan.period }}</span>
                {% endif %}
              </div>
              {% if plan.description %}
                <p class="plan-description">{{ plan.description }}</p>
              {% endif %}
              <ul class="plan-features">
                {% for feature in plan.features %}
                  <li class="{% if feature.included == false %}feature-excluded{% endif %}">
                    <i class="icon-{% if feature.included != false %}check{% else %}x{% endif %}"></i>
                    {{ feature.text or feature }}
                  </li>
                {% endfor %}
              </ul>
              <a href="{{ plan.ctaUrl or '/contact-us' }}" class="btn {% if plan.featured %}btn-primary{% else %}btn-secondary{% endif %} btn-block">
                {{ plan.ctaText or "Get Started" }}
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Technical Specs #}
  {% if specs %}
    <section class="technical-specs">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ specs.title or "Technical Specifications" }}</h2>
        </div>

        <div class="specs-table">
          {% for category in specs.categories %}
            <div class="specs-category">
              <h3>{{ category.name }}</h3>
              <table>
                {% for spec in category.items %}
                  <tr>
                    <td class="spec-label">{{ spec.label }}</td>
                    <td class="spec-value">{{ spec.value }}</td>
                  </tr>
                {% endfor %}
              </table>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# FAQ #}
  {% if faq %}
    <section class="faq-section">
      <div class="section-container">
        <div class="section-header">
          <h2>{{ faq.title or "Frequently Asked Questions" }}</h2>
        </div>

        <div class="faq-list">
          {% for item in faq.items %}
            <details class="faq-item">
              <summary class="faq-question">{{ item.question }}</summary>
              <div class="faq-answer">
                {{ item.answer | safe }}
              </div>
            </details>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Custom Content #}
  {% if content %}
    <section class="product-content">
      <div class="section-container">
        {{ content | safe }}
      </div>
    </section>
  {% endif %}
{% endblock %}

{% block ctaSection %}
  {% if cta %}
    {% include "components/sections/cta-section.njk" %}
  {% else %}
    <section class="product-cta">
      <div class="section-container">
        <div class="cta-content">
          <h2>Ready to Get Started?</h2>
          <p>Transform your business with {{ title }}</p>
          <div class="cta-actions">
            <a href="/contact-us" class="btn btn-primary btn-large">Contact Sales</a>
            <a href="/resources" class="btn btn-secondary btn-large">Learn More</a>
          </div>
        </div>
      </div>
    </section>
  {% endif %}
{% endblock %}