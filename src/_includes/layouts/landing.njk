---
layout: layouts/base.njk
---

{# Landing page template for marketing/promotional pages #}

{% block hero %}
  {% if hero %}
    {% include "components/sections/hero.njk" %}
  {% endif %}
{% endblock %}

{% block content %}
  {# Features Section #}
  {% if features %}
    <section class="features-section">
      <div class="section-container">
        {% if features.title %}
          <div class="section-header">
            <h2 class="section-title">{{ features.title }}</h2>
            {% if features.subtitle %}
              <p class="section-subtitle">{{ features.subtitle }}</p>
            {% endif %}
          </div>
        {% endif %}

        <div class="features-grid">
          {% for feature in features.items %}
            {% include "components/cards/feature-card.njk" %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Benefits Section #}
  {% if benefits %}
    <section class="benefits-section">
      <div class="section-container">
        {% if benefits.title %}
          <div class="section-header">
            <h2 class="section-title">{{ benefits.title }}</h2>
            {% if benefits.subtitle %}
              <p class="section-subtitle">{{ benefits.subtitle }}</p>
            {% endif %}
          </div>
        {% endif %}

        <div class="benefits-list">
          {% for benefit in benefits.items %}
            <div class="benefit-item">
              {% if benefit.icon %}
                <div class="benefit-icon">
                  <i class="icon-{{ benefit.icon }}"></i>
                </div>
              {% endif %}
              <div class="benefit-content">
                <h3>{{ benefit.title }}</h3>
                <p>{{ benefit.description }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Testimonials Section #}
  {% if testimonials %}
    <section class="testimonials-section">
      <div class="section-container">
        {% if testimonials.title %}
          <div class="section-header">
            <h2 class="section-title">{{ testimonials.title }}</h2>
          </div>
        {% endif %}

        <div class="testimonials-grid">
          {% for testimonial in testimonials.items %}
            {% include "components/cards/testimonial-card.njk" %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  {# Custom Content #}
  {% if content %}
    <section class="content-section">
      <div class="section-container">
        {{ content | safe }}
      </div>
    </section>
  {% endif %}
{% endblock %}

{% block ctaSection %}
  {% if cta %}
    {% include "components/sections/cta-section.njk" %}
  {% endif %}
{% endblock %}