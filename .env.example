# 🔐 Environment Variables Template
# Copy this file to .env and fill in your credentials
# cp .env.example .env

# ScrapFly API (Primary scraping method)
# Get your key from: https://scrapfly.io/dashboard/api
SCRAPFLY_API_KEY=scp-live-YOUR-KEY-HERE

# Oxylabs Proxy (Crawlee fallback method)
# Get credentials from: https://oxylabs.io/dashboard
OXYLABS_USERNAME=nachocoll_YOUR_USERNAME
OXYLABS_PASSWORD=YOUR_PASSWORD

# Anthropic Claude (AI evaluation and reply generation)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# Optional: Use Claude Sonnet for reply generation (higher quality, higher cost)
# DEFAULT: Uses Haiku (10x cheaper, faster, naturally shorter replies)
# Set to 'true' to upgrade to Sonnet for maximum quality
# Haiku benefits: $1.40/month vs $15/month for 900 replies (91% savings)
# Sonnet benefits: More creative/nuanced replies, better for VIP KOLs
# Default: not set (uses Haiku - cost optimized)
# USE_SONNET_FOR_REPLIES=true

# X/Twitter API (Optional - for posting replies)
# Get credentials from: https://developer.twitter.com
BWSXAI_TWITTER_BEARER_TOKEN=YOUR_BEARER_TOKEN
BWSXAI_TWITTER_API_KEY=YOUR_API_KEY
BWSXAI_TWITTER_API_SECRET=YOUR_API_SECRET
BWSXAI_TWITTER_ACCESS_TOKEN=YOUR_ACCESS_TOKEN
BWSXAI_TWITTER_ACCESS_SECRET=YOUR_ACCESS_SECRET
