---
import type { SuccessStory } from '../../data/successStories';
import SuccessStoryComponent from './SuccessStory.astro';

interface Props {
  stories: SuccessStory[];
}

const { stories } = Astro.props;
const storyCount = stories.length;
---

{
  storyCount > 1 ? (
    // Multiple stories - use Swiper carousel
    <>
      <div class="swiper success-stories-carousel">
        <div class="swiper-wrapper">
          {stories.map((story) => (
            <div class="swiper-slide">
              <SuccessStoryComponent story={story} />
            </div>
          ))}
        </div>
        <!-- Navigation arrows -->
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
      </div>

      <script define:vars={{ storyCount }}>
        // Initialize Swiper carousel when DOM is loaded
        document.addEventListener('DOMContentLoaded', function () {
          // @ts-ignore - Swiper is loaded via CDN
          if (typeof Swiper !== 'undefined') {
            // @ts-ignore
            new Swiper('.success-stories-carousel', {
              slidesPerView: 1,
              spaceBetween: 0,
              centeredSlides: true,
              loop: true,
              watchOverflow: true,
              autoplay: {
                delay: 8000, // 8 seconds (longer than news carousel)
                disableOnInteraction: false,
                pauseOnMouseEnter: true,
              },
              navigation: {
                nextEl: '.success-stories-carousel .swiper-button-next',
                prevEl: '.success-stories-carousel .swiper-button-prev',
              },
              breakpoints: {
                0: {
                  slidesPerView: 1,
                  spaceBetween: 0,
                },
              },
            });
          }
        });
      </script>

      <style>
        .success-stories-carousel {
          width: 100%;
          padding: 0 0 3rem 0;
          min-height: 400px;
          overflow: hidden;
        }

        /* Swiper wrapper - ensure no overflow */
        .success-stories-carousel .swiper-wrapper {
          align-items: stretch;
        }

        /* Swiper slide styling */
        .success-stories-carousel .swiper-slide {
          display: flex;
          justify-content: center;
          height: auto;
          width: 100%;
          flex-shrink: 0;
        }

        /* Ensure slide content takes full width */
        .success-stories-carousel .swiper-slide > * {
          width: 100%;
          max-width: 100%;
        }

        /* Customize Swiper navigation arrows */
        .success-stories-carousel .swiper-button-next,
        .success-stories-carousel .swiper-button-prev {
          background: rgba(255, 255, 255, 0.8);
          border-radius: 50%;
          width: 3rem;
          height: 3rem;
          color: #333;
        }

        .success-stories-carousel .swiper-button-next {
          right: 5px;
        }

        .success-stories-carousel .swiper-button-prev {
          left: 5px;
        }

        .success-stories-carousel .swiper-button-next:hover,
        .success-stories-carousel .swiper-button-prev:hover {
          background: rgba(255, 255, 255, 1);
        }

        .success-stories-carousel .swiper-button-next::after,
        .success-stories-carousel .swiper-button-prev::after {
          font-size: 1.5rem;
          font-weight: bold;
        }

        /* Hide pagination dots */
        .success-stories-carousel .swiper-pagination {
          display: none !important;
        }

        /* Mobile adjustments */
        @media screen and (max-width: 991px) {
          .success-stories-carousel {
            padding: 0 0.5rem 2rem 0.5rem;
          }
        }
      </style>
    </>
  ) : (
    // Single story - no carousel, just display it
    <SuccessStoryComponent story={stories[0]} />
  )
}
