{
  "extends": ["html-validate:recommended"],
  "rules": {
    "doctype-html": "error",
    "no-duplicate-id": "error",
    "no-duplicate-attr": "error",
    "close-attr": "error",
    "close-order": "error",
    "element-permitted-content": "error",
    "element-required-attributes": "error",
    "attribute-boolean-style": ["error", { "style": "empty" }],
    "attr-quotes": ["error", { "style": "double" }],
    "no-trailing-whitespace": "error",
    "void-style": ["error", { "style": "selfclosing" }],
    "no-inline-style": "off",
    "script-type": "off",
    "require-sri": "off",
    "no-unknown-elements": "error",
    "heading-level": "error",
    "meta-refresh": "error",
    "no-missing-references": "error",
    "prefer-native-element": "warn",
    "wcag/h30": "warn",
    "wcag/h32": "warn",
    "wcag/h36": "warn",
    "wcag/h37": "warn",
    "wcag/h67": "warn",
    "wcag/h71": "warn"
  },
  "elements": [
    "html5"
  ]
}