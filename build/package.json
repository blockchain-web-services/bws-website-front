{
  "name": "bws-website-build",
  "version": "1.0.0",
  "description": "Build tools for BWS website",
  "scripts": {
    "dev": "cd .. && ./build/node_modules/.bin/astro dev",
    "start": "cd .. && ./build/node_modules/.bin/astro dev",
    "prebuild": "node clean-build.js",
    "build": "node build-with-validation.js",
    "build:old": "npm run prebuild && cd .. && ./build/node_modules/.bin/astro build && cd build && npm run postbuild",
    "build:only": "cd .. && ./build/node_modules/.bin/astro build",
    "build:fast": "npm run prebuild && cd .. && ./build/node_modules/.bin/astro build",
    "postbuild": "npm run pretty-print && npm run validate",
    "preview": "cd .. && ./build/node_modules/.bin/astro preview",
    "crawl": "node crawler/crawl-standalone.js",
    "redownload": "node redownload-all-pages.js",
    "validate": "node html-validator.js",
    "validate:old": "node validate-html.js",
    "prettify": "node html-prettifier.js",
    "pretty-print": "node pretty-print-validate.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "astro": "^4.16.18",
    "cheerio": "^1.1.2",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "html-validator": "^6.0.0",
    "linkinator": "^6.0.0",
    "node-fetch": "^3.3.2",
    "prettier": "^3.6.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.50.2"
  }
}