module.exports = function(eleventyConfig) {
  // Set Nunjucks as the template engine
  eleventyConfig.setTemplateFormats(["njk", "html", "md"]);
  
  // Copy static assets
  eleventyConfig.addPassthroughCopy("src/assets");
  eleventyConfig.addPassthroughCopy("src/**/*.css");
  eleventyConfig.addPassthroughCopy("src/**/*.js");
  eleventyConfig.addPassthroughCopy("src/**/*.jpg");
  eleventyConfig.addPassthroughCopy("src/**/*.png");
  eleventyConfig.addPassthroughCopy("src/**/*.svg");
  
  // Add custom filters
  eleventyConfig.addFilter("dateFormat", function(date) {
    const d = new Date(date);
    return d.toLocaleDateString('en-US', { 
      year: 'numeric', 
      month: 'long', 
      day: 'numeric' 
    });
  });
  
  // Add filter for safe HTML output
  eleventyConfig.addFilter("safe", function(content) {
    return content;
  });
  
  // Add collection for marketplace pages
  eleventyConfig.addCollection("marketplace", function(collectionApi) {
    return collectionApi.getFilteredByGlob("src/marketplace/*.njk");
  });
  
  // Add shortcodes for buttons
  eleventyConfig.addShortcode("ctaPrimary", function(text, href, icon = "", size = "medium") {
    const iconHtml = icon ? `<i class="icon-${icon}"></i> ` : "";
    return `<a href="${href}" class="btn btn-primary btn-${size}" data-analytics="cta-click">
      ${iconHtml}<span>${text}</span>
    </a>`;
  });
  
  eleventyConfig.addShortcode("ctaSecondary", function(text, href, size = "medium") {
    return `<a href="${href}" class="btn btn-secondary btn-${size}">
      <span>${text}</span>
    </a>`;
  });
  
  // Add shortcode for navigation links
  eleventyConfig.addShortcode("navLink", function(text, href, style = "default") {
    const styleClasses = {
      "nav-dropdown": "nav-link dropdown-item",
      "footer": "footer-link",
      "inline": "text-link",
      "card": "card-link stretched-link",
      "default": ""
    };
    
    return `<a href="${href}" class="${styleClasses[style]}">${text}</a>`;
  });
  
  // Configure Nunjucks
  eleventyConfig.setNunjucksEnvironmentOptions({
    throwOnUndefined: false,
    autoescape: true
  });
  
  // Watch for changes
  eleventyConfig.addWatchTarget("src/**/*.css");
  eleventyConfig.addWatchTarget("src/**/*.js");
  
  // Return configuration
  return {
    dir: {
      input: "src",
      output: "_site",
      includes: "_includes",
      data: "_data"
    },
    markdownTemplateEngine: "njk",
    htmlTemplateEngine: "njk",
    dataTemplateEngine: "njk"
  };
};